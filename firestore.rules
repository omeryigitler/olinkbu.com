rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'yigitleromer@gmail.com'
      );
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Helpers ---
    function isOptionalString(data, field, maxLength) {
      return !(field in data) || data[field] == null || (data[field] is string && data[field].size() <= maxLength);
    }

    function isValidNonNegativeNumber(value) {
      return value is number && value >= 0;
    }

    function isValidReactions(data) {
      return !('reactions' in data) || (
        data.reactions is map &&
        data.reactions.keys().hasOnly(['lightbulb', 'deep', 'fire', 'inspire']) &&
        (!('lightbulb' in data.reactions) || isValidNonNegativeNumber(data.reactions.lightbulb)) &&
        (!('deep' in data.reactions) || isValidNonNegativeNumber(data.reactions.deep)) &&
        (!('fire' in data.reactions) || isValidNonNegativeNumber(data.reactions.fire)) &&
        (!('inspire' in data.reactions) || isValidNonNegativeNumber(data.reactions.inspire))
      );
    }

    function isValidSnippet(data) {
      return data.keys().hasOnly([
               'userId',
               'userName',
               'userPhoto',
               'videoUrl',
               'videoId',
               'platform',
               'startSec',
               'endSec',
               'comment',
               'category',
               'likesCount',
               'reactions',
               'createdAt'
             ]) &&
             data.keys().hasAll(['userId', 'videoId', 'platform', 'startSec', 'endSec', 'comment', 'category', 'likesCount', 'createdAt']) &&
             data.userId == request.auth.uid &&
             isOptionalString(data, 'userName', 120) &&
             isOptionalString(data, 'userPhoto', 1000) &&
             isOptionalString(data, 'videoUrl', 1000) &&
             data.videoId is string && data.videoId.size() <= 128 &&
             data.platform in ['youtube', 'spotify'] &&
             isValidNonNegativeNumber(data.startSec) &&
             isValidNonNegativeNumber(data.endSec) &&
             data.endSec >= data.startSec &&
             data.comment is string && data.comment.size() > 0 && data.comment.size() <= 500 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 40 &&
             data.likesCount == 0 &&
             isValidReactions(data) &&
             data.createdAt == request.time;
    }

    function isValidSnippetOwnerUpdate(data) {
      return data.comment is string && data.comment.size() > 0 && data.comment.size() <= 500 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 40;
    }

    function isValidReaction(data, userId) {
      return data.keys().hasOnly(['userId', 'reactionType', 'category', 'platform', 'createdAt', 'updatedAt']) &&
             data.keys().hasAll(['userId', 'reactionType', 'createdAt']) &&
             data.userId == userId &&
             data.reactionType in ['lightbulb', 'deep', 'fire', 'inspire'] &&
             isOptionalString(data, 'category', 40) &&
             isOptionalString(data, 'platform', 40) &&
             data.createdAt == request.time &&
             (!('updatedAt' in data) || data.updatedAt == request.time);
    }

    function isValidComment(data) {
      return data.keys().hasOnly(['userId', 'userName', 'userPhoto', 'text', 'createdAt']) &&
             data.keys().hasAll(['userId', 'text', 'createdAt']) &&
             data.userId == request.auth.uid &&
             isOptionalString(data, 'userName', 120) &&
             isOptionalString(data, 'userPhoto', 1000) &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 300 &&
             data.createdAt == request.time;
    }

    function isValidUserProfile(data, userId) {
      return data.keys().hasOnly(['uid', 'displayName', 'photoURL', 'bio', 'createdAt', 'updatedAt']) &&
             (!('uid' in data) || data.uid == userId) &&
             isOptionalString(data, 'displayName', 120) &&
             isOptionalString(data, 'photoURL', 1000) &&
             isOptionalString(data, 'bio', 300) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt == request.time);
    }

    function isValidSave(data, userId, snippetId) {
      return data.keys().hasOnly(['userId', 'snippetId', 'ownerId', 'category', 'platform', 'createdAt']) &&
             data.keys().hasAll(['userId', 'snippetId', 'createdAt']) &&
             data.userId == userId &&
             data.snippetId == snippetId &&
             isOptionalString(data, 'ownerId', 128) &&
             isOptionalString(data, 'category', 40) &&
             isOptionalString(data, 'platform', 40) &&
             data.createdAt == request.time;
    }

    function isValidTasteEvent(data, userId) {
      return data.keys().hasOnly(['userId', 'type', 'snippetId', 'reactionType', 'category', 'platform', 'createdAt']) &&
             data.keys().hasAll(['userId', 'type', 'createdAt']) &&
             data.userId == userId &&
             data.type in ['save', 'reaction', 'follow', 'collection_add', 'share', 'skip', 'watch_complete'] &&
             isOptionalString(data, 'snippetId', 128) &&
             isOptionalString(data, 'reactionType', 40) &&
             isOptionalString(data, 'category', 40) &&
             isOptionalString(data, 'platform', 40) &&
             data.createdAt == request.time;
    }

    // --- Routes ---

    // Public Feed & Snippets
    match /snippets/{snippetId} {
      allow list, get: if true; // Publicly readable feed
      allow create: if isSignedIn() && isValidSnippet(incoming());
      allow update: if isSignedIn() &&
        isOwner(existing().userId) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['comment', 'category']) &&
        isValidSnippetOwnerUpdate(incoming());
      allow delete: if isSignedIn() && (isOwner(existing().userId) || isAdmin());

      // One reaction edge per user per snippet. Counters should be derived server-side later.
      match /reactions/{userId} {
        allow list, get: if true;
        allow create, update: if isOwner(userId) && isValidReaction(incoming(), userId);
        allow delete: if isOwner(userId) || isAdmin();
      }

      // Comments sub-collection
      match /comments/{commentId} {
        allow list, get: if true;
        allow create: if isSignedIn() && isValidComment(incoming());
        allow delete: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      }
    }

    // User Profiles
    match /users/{userId} {
      allow get: if true;
      allow list: if false; // Prevention of user scraping
      allow create, update: if isSignedIn() && isOwner(userId) && isValidUserProfile(incoming(), userId);
      allow delete: if isAdmin();

      // Cloud synced saves, replacing localStorage-only saved snippets.
      match /saves/{snippetId} {
        allow list, get: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidSave(incoming(), userId, snippetId);
        allow delete: if isOwner(userId) || isAdmin();
      }

      // Append-only taste events for future recommendation and DNA scoring jobs.
      match /tasteEvents/{eventId} {
        allow list, get: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidTasteEvent(incoming(), userId);
        allow update, delete: if false;
      }
    }

    // Admins
    match /admins/{userId} {
      allow get: if isSignedIn();
      allow write: if false;
    }
  }
}
